# ── .env.local — local developer overrides ────────────────────────────────
#
# Copy to .env.local (already gitignored) and fill in your local values.
# These override anything in .env but are overridden by Render env vars.
#
#   cp .env.local.example .env.local

DATABASE_URL=postgresql://postgres:password@localhost:5432/goldshop
SECRET_KEY=local-dev-secret-not-used-in-production
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500
