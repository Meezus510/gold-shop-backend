# ── Gold Shop Backend — environment variables ──────────────────────────────
#
# Copy this file:
#   Local dev  →  cp .env.example .env.local   (never committed)
#   Production →  set these as env vars in the Render dashboard
#
# Priority order (highest wins):
#   1. Render dashboard env vars  (production)
#   2. .env.local                 (local overrides)
#   3. .env                       (shared defaults)

# ── Database ───────────────────────────────────────────────────────────────
# Local:      postgresql://postgres:password@localhost:5432/goldshop
# Render:     auto-injected via render.yaml fromDatabase binding
DATABASE_URL=postgresql://user:password@localhost:5432/goldshop

# ── JWT ────────────────────────────────────────────────────────────────────
# Production: use a long random string (Render can auto-generate via render.yaml)
# Generate one locally: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes).
# Local dev defaults are set in settings.py; override here for production.
# Example: https://anabels-joyeria.netlify.app,https://www.anabelsjoyeria.com
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500
